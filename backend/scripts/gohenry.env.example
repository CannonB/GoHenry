# Copy to gohenry.env and fill in. gohenry.env is git-ignored — never commit secrets.

# Unique-ish tag woven into every global resource name (keep it short, lowercase).
GOHENRY_SUFFIX=demo
GOHENRY_LOCATION=eastus

# Ford developer app — REUSE the existing Ford developer application's credentials.
FORD_SLUG=primary
FORD_CLIENT_ID=
FORD_CLIENT_SECRET=
FORD_OAUTH_BASE=https://api.vehicle.ford.com/
FORD_API_BASE=https://api.vehicle.ford.com/
FORD_SCOPE=access
